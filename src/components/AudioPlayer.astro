---
interface Props {
  src: string;
  type?: string;
}

const { src, type = "audio/mpeg" } = Astro.props;
---

<audio class="player" controls preload="metadata">
  <source src={src} type={type} />
  Your browser does not support the audio element.
</audio>

<style>
  .player {
    width: 100%;
    height: 44px;
    margin-top: 0.4rem;
    border-radius: 999px;
    filter: sepia(0.2) contrast(1.03);
  }
</style>
