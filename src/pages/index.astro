---
import { getCollection, getEntry, render } from "astro:content";
import ContactBlock from "../components/ContactBlock.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import SocialLinks from "../components/SocialLinks.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const home = await getEntry("pages", "home");

if (!home) {
  throw new Error("Homepage content entry is missing.");
}

const { Content } = await render(home);

const releases = await getCollection("releases");
const updates = await getCollection("updates");

const latestUpdate = updates.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];
const latestRelease = releases[0];
---

<BaseLayout title={home.data.seoTitle} description={home.data.seoDescription}>
  <Hero
    title={home.data.title}
    tagline={home.data.tagline}
    logoSrc="/image/Athas_Logo_transparent.png"
    logoAlt="Aþas band logo"
  />

  <Section title="Listen">
    <div class="listen-panel">
      <p class="listen-meta">Liegetsliht — demo snippet</p>
      <audio class="song-player" controls preload="metadata">
        <source src="/music/Liegetsliht_demo.mp3" type="audio/mpeg" />
        Your browser does not support the audio element.
      </audio>
      <p class="listen-note">Demo excerpt. Full release forthcoming.</p>
    </div>
  </Section>

  <Section title="The Vision">
    <div class="prose-panel">
      <Content />
    </div>
  </Section>

  <Section title="Current Work">
    <div class="current-panel">
      <p>{home.data.status}</p>
      <ul class="current-highlights">
        <li>Debut material in finalization.</li>
        <li>Live lineup preparation underway.</li>
        <li>Open to label and promoter collaborations.</li>
      </ul>
    </div>
  </Section>

  <Section title="Chronicles">
    <div class="teaser-grid">
      {
        latestUpdate && (
          <article class="teaser-card">
            <p class="teaser-label">Latest update</p>
            <h3>{latestUpdate.data.title}</h3>
            <p class="teaser-meta">
              {latestUpdate.data.date.toISOString().slice(0, 10)}
            </p>
            <p>{latestUpdate.data.summary}</p>
            <a class="teaser-link" href="/updates">
              Read all updates
            </a>
          </article>
        )
      }

      {
        latestRelease && (
          <article class="teaser-card">
            <p class="teaser-label">Current release</p>
            <h3>{latestRelease.data.title}</h3>
            <p class="teaser-meta">{latestRelease.data.format}</p>
            <p>Status: {latestRelease.data.status}</p>
            <p>Release: {latestRelease.data.releaseDate}</p>
            <a class="teaser-link" href="/releases">
              View releases
            </a>
          </article>
        )
      }
    </div>
  </Section>

  <Section title="Contact">
    <p class="contact-intro">
      For bookings, support slots, and collaborations, reach out directly.
    </p>
    <ContactBlock bookingEmail={home.data.bookingEmail} />
    <div class="contact-socials">
      <SocialLinks socials={home.data.socials} />
    </div>
  </Section>

  <aside class="social-side-panel" aria-label="Aþas social links">
    <p class="social-side-title">Follow</p>
    <SocialLinks socials={home.data.socials} />
  </aside>
</BaseLayout>
