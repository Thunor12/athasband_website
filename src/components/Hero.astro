---
import bindRuneBg from "../assets/hero/BindRune_2.jpg";
import defaultLogo from "../assets/brand/Athas_Logo_transparent.png";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  title: string;
  tagline: string;
  logoSrc?: ImageMetadata;
  logoAlt?: string;
  bannerText?: string;
  runicName?: string;
  availabilityText?: string;
  bookingEmail?: string;
}

const {
  title,
  tagline,
  logoSrc = defaultLogo,
  logoAlt = "Aþas logo",
  bannerText,
  runicName = "ᚪᚦᚪᚴ",
  availabilityText,
  bookingEmail,
} = Astro.props;
---

<header class="hero">
  <div class="hero-art" aria-hidden="true">
    <Image
      src={bindRuneBg}
      alt=""
      class="hero-bindrune"
      width={1518}
      height={2047}
      loading="eager"
      decoding="async"
      sizes="100vw"
    />
  </div>
  <p class="hero-banner">{bannerText}</p>
  <p class="hero-subline">{tagline}</p>
  <h1>{title}</h1>
  <p class="hero-runes" aria-label="Runic inscription of Aþas">{runicName}</p>
  <p class="hero-availability">{availabilityText}</p>
  <Image
    src={logoSrc}
    alt={logoAlt}
    class="hero-logo"
    widths={[480, 700, 960]}
    sizes="(max-width: 900px) 88vw, 700px"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  {
    bookingEmail && (
      <p class="hero-contact">
        Contact: <a href={`mailto:${bookingEmail}`}>{bookingEmail}</a>
      </p>
    )
  }
</header>

<style>
  .hero {
    min-height: calc(100svh - var(--topbar-h) - 1rem);
    max-height: calc(100svh - var(--topbar-h) - 1rem);
    margin-bottom: 1.4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(0.25rem, 0.95svh, 0.75rem);
    padding-top: 0;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(181, 150, 90, 0.14);
    border-radius: 6px;
  }

  :global(.js) .hero {
    animation: hero-enter 950ms cubic-bezier(0.2, 0.9, 0.2, 1) both;
  }

  :global(.js) .hero > *:not(.hero-art) {
    opacity: 0;
    transform: translateY(14px);
    animation: hero-item-enter 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  :global(.js) .hero .hero-banner {
    animation-delay: 120ms;
  }

  :global(.js) .hero h1 {
    animation-delay: 230ms;
  }

  :global(.js) .hero .hero-runes {
    animation-delay: 340ms;
  }

  :global(.js) .hero .hero-availability {
    animation-delay: 450ms;
  }

  :global(.js) .hero .hero-logo {
    animation-delay: 560ms;
  }

  :global(.js) .hero .hero-contact {
    animation-delay: 640ms;
  }

  @keyframes hero-enter {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.992);
      filter: saturate(0.86);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: saturate(1);
    }
  }

  @keyframes hero-item-enter {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle at center,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.42) 58%,
      rgba(0, 0, 0, 0.82) 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  .hero-art {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    opacity: 1;
    transform: none;
    animation: none;
  }

  .hero-bindrune {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.1) translate(0.5%, -5%);
    transform-origin: center;
    opacity: 0.1;
    filter: sepia(0.6) contrast(0.80) saturate(0.85);
  }

  :global(.js) .hero-bindrune {
    animation: bindrune-drift 28s ease-in-out infinite alternate;
  }

  @keyframes bindrune-drift {
    from {
      transform: scale(1.1) translate(0.5%, -5%);
    }
    to {
      transform: scale(1.14) translate(-0.8%, -3.5%);
    }
  }

  .hero > *:not(.hero-art) {
    position: relative;
    z-index: 1;
  }

  .hero-logo {
    display: block;
    width: min(88vw, 56vh, 700px);
    max-width: 100%;
    max-height: min(54svh, 500px);
    height: auto;
    object-fit: contain;
    margin: 0 auto;
    filter:
      drop-shadow(0 0 10px rgba(181, 150, 90, 0.14))
      drop-shadow(0 0 26px rgba(181, 150, 90, 0.16))
      drop-shadow(0 0 58px rgba(181, 150, 90, 0.1));
  }

  .hero-banner {
    font-family: "EB Garamond", "Times New Roman", serif;
    color: #ebdfbf;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: clamp(0.84rem, 0.74rem + 0.34vw, 1.06rem);
    font-weight: 600;
    opacity: 0.85;
    margin: 0;
    padding: 0.22rem 0.74rem;
    border-top: 1px solid rgba(220, 196, 123, 0.38);
    border-bottom: 1px solid rgba(220, 196, 123, 0.38);
    background: linear-gradient(
      90deg,
      rgba(181, 150, 90, 0.08) 0%,
      rgba(181, 150, 90, 0.2) 50%,
      rgba(181, 150, 90, 0.08) 100%
    );
  }

  .hero-subline {
    margin: -0.35rem 0 0;
    color: #cfc6b0;
    font-size: clamp(0.86rem, 0.76rem + 0.24vw, 1.02rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero-runes {
    font-family: "Ringbearer", "Times New Roman", serif;
    color: rgba(205, 179, 114, 0.95);
    font-size: clamp(0.9rem, 2.2vw, 1.2rem);
    letter-spacing: 0.2em;
    margin: 0;
    text-shadow: 0 0 18px rgba(220, 196, 123, 0.2);
    opacity: 0.6;
  }

  .hero-availability {
    margin: 0;
    color: #e0cd9e;
    font-size: clamp(0.8rem, 0.72rem + 0.24vw, 0.94rem);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    opacity: 0.75;
  }

  .hero-contact {
    margin: 0.15rem 0 0;
    color: rgba(218, 200, 155, 0.78);
    font-size: clamp(0.68rem, 0.62rem + 0.16vw, 0.8rem);
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }

  .hero-contact a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(218, 200, 155, 0.28);
    transition: color 180ms ease, border-color 180ms ease, opacity 180ms ease;
  }

  .hero-contact a:hover,
  .hero-contact a:focus-visible {
    color: #f1e0b4;
    border-bottom-color: rgba(241, 224, 180, 0.7);
  }

  @media (max-width: 520px) {
    .hero-bindrune {
      opacity: 0.12;
    }
  }

  @media (max-height: 760px) {
    .hero {
      gap: 0.35rem;
    }

    .hero-logo {
      max-height: 40svh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.js) .hero,
    :global(.js) .hero > * {
      animation: none;
      opacity: 1;
      transform: none;
    }

    :global(.js) .hero-bindrune {
      animation: none;
    }
  }
</style>
