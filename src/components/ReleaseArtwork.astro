---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
  title?: string;
  href?: string;
  priority?: boolean;
}

const { src, alt, title, href, priority = false } = Astro.props;
const hasLink = Boolean(href);
---

<div class="release-artwork">
  {
    hasLink ? (
      <a
        class="atropos cd-atropos"
        data-atropos
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open ${title ?? "this release"} on Bandcamp`}
      >
        <div class="atropos-scale">
          <div class="atropos-rotate">
            <div class="atropos-inner">
              <div class="cd-mockup">
                <span class="cd-shadow" aria-hidden="true" data-atropos-offset="-6"></span>
                <div class="cd-disc" data-atropos-offset="3">
                  <Image
                    src={src}
                    alt={alt}
                    class="cd-art"
                    widths={[420, 640, 960]}
                    sizes="(max-width: 900px) 84vw, 360px"
                    loading={priority ? "eager" : "lazy"}
                    fetchpriority={priority ? "high" : "auto"}
                    decoding="async"
                  />
                  <span class="cd-iridescence" aria-hidden="true"></span>
                  <span class="cd-rings" aria-hidden="true"></span>
                  <span class="cd-hole" aria-hidden="true"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </a>
    ) : (
      <div class="atropos cd-atropos" data-atropos>
        <div class="atropos-scale">
          <div class="atropos-rotate">
            <div class="atropos-inner">
              <div class="cd-mockup">
                <span class="cd-shadow" aria-hidden="true" data-atropos-offset="-6"></span>
                <div class="cd-disc" data-atropos-offset="3">
                  <Image
                    src={src}
                    alt={alt}
                    class="cd-art"
                    widths={[420, 640, 960]}
                    sizes="(max-width: 900px) 84vw, 360px"
                    loading={priority ? "eager" : "lazy"}
                    fetchpriority={priority ? "high" : "auto"}
                    decoding="async"
                  />
                  <span class="cd-iridescence" aria-hidden="true"></span>
                  <span class="cd-rings" aria-hidden="true"></span>
                  <span class="cd-hole" aria-hidden="true"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    )
  }

  <p class="release-artwork-caption">
    {title ? `${title} artwork` : "Release artwork preview"}
    {hasLink && " · Open on Bandcamp"}
  </p>
</div>

{/* Classic script tags — avoid Astro module bundling / reduced-motion early-outs */}
<script is:inline src="/vendor/atropos.min.js"></script>
<script is:inline>
  (function () {
    function mount() {
      if (typeof Atropos !== "function") return;
      document.querySelectorAll("[data-atropos]").forEach(function (el) {
        if (el.__atropos__ && typeof el.__atropos__.destroy === "function") {
          el.__atropos__.destroy();
        }
        Atropos({
          el: el,
          activeOffset: 28,
          shadowScale: 1.02,
          highlight: false,
          shadow: true,
          rotateTouch: "scroll-y",
        });
        el.setAttribute("data-atropos-ready", "1");
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", mount);
    } else {
      mount();
    }
  })();
</script>

<style>
  .release-artwork {
    margin: 0.25rem 0 1rem;
    text-align: center;
  }

  .cd-atropos {
    display: block;
    width: min(84vw, 360px);
    height: min(84vw, 360px);
    margin: 0 auto;
    text-decoration: none;
    color: inherit;
    border-radius: 50%;
    clip-path: circle(50% at 50% 50%);
  }

  .cd-atropos:focus-visible {
    outline: 1px solid rgba(220, 196, 123, 0.72);
    outline-offset: 4px;
  }

  .cd-atropos :global(.atropos-scale),
  .cd-atropos :global(.atropos-rotate),
  .cd-atropos :global(.atropos-inner),
  .cd-mockup,
  .cd-disc {
    border-radius: 50%;
  }

  .cd-atropos :global(.atropos-inner) {
    background: transparent;
    overflow: hidden;
  }

  /* Override Atropos default blur(30px) — soft disc shadow only */
  .cd-atropos :global(.atropos-shadow) {
    border-radius: 50%;
    filter: blur(8px) !important;
    background: rgba(0, 0, 0, 0.55);
  }

  .cd-atropos :global(.atropos-active .atropos-shadow) {
    opacity: 0.35 !important;
  }

  .cd-mockup {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    clip-path: circle(50% at 50% 50%);
  }

  /* Drop the extra soft plate — Atropos shadow is enough */
  .cd-shadow {
    display: none;
  }

  .cd-disc {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border: 1px solid rgba(198, 195, 181, 0.4);
    background:
      radial-gradient(circle at 50% 50%, #1a1a1e 0%, #0e0e10 70%);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.07);
    clip-path: circle(50% at 50% 50%);
  }

  .cd-art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: contain;
    object-position: center;
    padding: 16%;
    box-sizing: border-box;
    pointer-events: none;
    z-index: 2;
    opacity: 1;
  }

  .cd-iridescence,
  .cd-rings,
  .cd-hole {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* Quiet outer-rim texture — fade out toward the label */
  .cd-rings {
    z-index: 1;
    opacity: 0.85;
    background:
      radial-gradient(
        circle,
        transparent 0 8.5%,
        rgba(210, 198, 168, 0.4) 5.5% 6.6%,
        rgba(28, 29, 34, 0.45) 6.6% 7.6%,
        rgba(200, 188, 158, 0.18) 7.6% 9.5%,
        transparent 10.5% 100%
      ),
      repeating-radial-gradient(
        circle at center,
        transparent 1px,
        transparent 6px,
        rgba(210, 200, 175, 0.22) 6px,
        rgba(210, 200, 175, 0.22) 6.5px,
        rgba(0, 0, 0, 0.12) 6.5px,
        rgba(0, 0, 0, 0.12) 9px
      );
    -webkit-mask-image: radial-gradient(
      circle,
      transparent 0 5%,
      #000 5.2% 9.8%,
      transparent 11% 58%,
      rgba(0, 0, 0, 0.2) 68%,
      #000 82% 96%,
      transparent 99%
    );
    mask-image: radial-gradient(
      circle,
      transparent 0 8%,
      #000 5.2% 9.8%,
      transparent 11% 58%,
      rgba(0, 0, 0, 0.2) 68%,
      #000 82% 96%,
      transparent 99%
    );
  }

  .cd-iridescence {
    z-index: 3;
    opacity: 0.12;
    background: radial-gradient(
      circle at 28% 22%,
      rgba(255, 255, 255, 0.2),
      rgba(255, 255, 255, 0) 42%
    );
    mix-blend-mode: soft-light;
  }

  .cd-hole {
    inset: 47.2%;
    z-index: 4;
    border-radius: 50%;
    border: 1px solid rgba(38, 39, 46, 0.5);
    background: #efe9da;
    box-shadow: inset 0 0 3px rgba(0, 0, 0, 0.25);
  }

  .release-artwork-caption {
    margin: 0.55rem 0 0;
    font-size: 0.82rem;
    color: #bdae89;
    text-align: center;
    letter-spacing: 0.03em;
  }
</style>
