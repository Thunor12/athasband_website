---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  priority?: boolean;
  widths?: number[];
  sizes?: string;
}

const {
  src,
  alt,
  caption,
  priority = false,
  widths = [640, 960, 1280],
  sizes = "(max-width: 900px) 92vw, 680px",
} = Astro.props;
const isStringSource = typeof src === "string";
---

<figure class="content-image">
  {
    isStringSource ? (
      <img
        src={src}
        alt={alt}
        loading={priority ? "eager" : "lazy"}
        decoding="async"
      />
    ) : (
      <Image
        src={src}
        alt={alt}
        widths={widths}
        sizes={sizes}
        loading={priority ? "eager" : "lazy"}
        fetchpriority={priority ? "high" : "auto"}
        decoding="async"
      />
    )
  }
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .content-image {
    margin: 1rem 0;
  }

  .content-image :global(img) {
    display: block;
    width: 100%;
    max-width: 680px;
    height: auto;
    margin: 0 auto;
    border: 1px solid rgba(181, 150, 90, 0.28);
  }

  .content-image figcaption {
    margin-top: 0.45rem;
    font-size: 0.82rem;
    color: #bdae89;
    text-align: center;
    letter-spacing: 0.03em;
  }
</style>
