---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContentImage from "../components/ContentImage.astro";

const updates = await getCollection("updates");
const sorted = updates.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const renderedUpdates = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);

    return {
      ...entry,
      Content,
    };
  }),
);

let priorityCoverUsed = false;
const updatesWithCovers = renderedUpdates.map((entry) => {
  const priorityCover = Boolean(entry.data.coverImage && !priorityCoverUsed);

  if (priorityCover) {
    priorityCoverUsed = true;
  }

  return {
    ...entry,
    priorityCover,
  };
});
---

<BaseLayout title="Aþas | Updates" description="News and Instagram posts from Aþas.">
  <h1>Updates</h1>
  <p class="page-intro">
    Posts and announcements from the band : mirrored from
    <a href="https://www.instagram.com/athas.band/" target="_blank" rel="noreferrer">@athas.band on Instagram</a>.
  </p>
  <ul class="stack-list">
    {
      updatesWithCovers.map((entry) => (
        <li class="stack-item">
          <p class="update-type">
            {entry.data.instagramUrl ? "Instagram post" : "Update"}
            {entry.data.format && ` · ${entry.data.format}`}
          </p>
          <h2>{entry.data.title}</h2>
          {
            entry.data.coverImage && (
              <ContentImage
                src={entry.data.coverImage}
                alt={entry.data.coverAlt ?? entry.data.title}
                priority={entry.priorityCover}
              />
            )
          }
          <p>{entry.data.date.toISOString().slice(0, 10)}</p>
          <p>{entry.data.summary}</p>
          {
            (entry.data.instagramUrl || entry.data.instagramReelUrl) && (
              <p class="update-instagram-links">
                {
                  entry.data.instagramUrl && (
                    <a
                      href={entry.data.instagramUrl}
                      target="_blank"
                      rel="noreferrer"
                    >
                      View on Instagram
                      {entry.data.format === "reel" ? " (reel)" : ""}
                    </a>
                  )
                }
                {
                  entry.data.instagramReelUrl && (
                    <>
                      {entry.data.instagramUrl && " · "}
                      <a
                        href={entry.data.instagramReelUrl}
                        target="_blank"
                        rel="noreferrer"
                      >
                        Watch reel
                      </a>
                    </>
                  )
                }
              </p>
            )
          }
          <entry.Content />
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .update-type {
    margin: 0 0 0.35rem;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #b5965a;
  }

  .update-instagram-links {
    margin: 0.35rem 0 0.65rem;
    font-size: 0.92rem;
    color: var(--muted);
  }

  .update-instagram-links a {
    color: #bdae89;
  }
</style>
