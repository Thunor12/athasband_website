---
interface Social {
  name: string;
  url: string;
}

interface Props {
  socials: Social[];
}

const { socials } = Astro.props;
---

<ul class="social-links">
  {
    socials.map((social) => (
      <li>
        <a href={social.url} target="_blank" rel="noreferrer">{social.name}</a>
      </li>
    ))
  }
</ul>

<style>
  .social-links {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(181, 150, 90, 0.3);
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    font-size: 0.88rem;
    letter-spacing: 0.03em;
    color: #d2c8b0;
    background: rgba(181, 150, 90, 0.08);
    transition: border-color 140ms ease, background-color 140ms ease,
      color 140ms ease;
  }

  .social-links a:hover {
    text-decoration: none;
    border-color: rgba(220, 196, 123, 0.8);
    background: rgba(181, 150, 90, 0.16);
    color: #f2e4c5;
  }
</style>
