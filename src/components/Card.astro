---
import Panel from "./Panel.astro";

interface Props {
  label: string;
  title: string;
  meta?: string;
  lines?: string[];
  href: string;
  linkText: string;
}

const { label, title, meta, lines = [], href, linkText } = Astro.props;
---

<Panel>
  <p class="label">{label}</p>
  <h3>{title}</h3>
  {meta && <p class="meta">{meta}</p>}
  {lines.map((line) => <p class="body">{line}</p>)}
  <a class="link" href={href}>{linkText}</a>
</Panel>

<style>
  .label {
    margin: 0 0 0.25rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c8b58c;
  }

  h3 {
    margin: 0 0 0.35rem;
    color: #dcc794;
    font-size: 1.14rem;
    font-family: "Ringbearer", "Times New Roman", serif;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .meta {
    margin: 0 0 0.45rem;
    color: #bbaf94;
    font-size: 0.92rem;
  }

  .body {
    margin: 0 0 0.45rem;
  }

  .body:last-of-type {
    margin-bottom: 0.7rem;
  }

  .link {
    display: inline-block;
    border: 1px solid rgba(181, 150, 90, 0.35);
    border-radius: 999px;
    padding: 0.2rem 0.62rem;
    font-size: 0.84rem;
    color: #e0cd9e;
  }

  .link:hover {
    text-decoration: none;
    background: rgba(181, 150, 90, 0.14);
  }
</style>
