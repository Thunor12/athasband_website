---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";

const updates = await getCollection("updates");
const sorted = updates.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const renderedUpdates = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);

    return {
      ...entry,
      Content,
    };
  }),
);
---

<BaseLayout title="Aþas | Updates" description="News and progress updates from Aþas.">
  <h1>Updates</h1>
  <ul class="stack-list">
    {
      renderedUpdates.map((entry) => (
        <li class="stack-item">
          <h2>{entry.data.title}</h2>
          <p>{entry.data.date.toISOString().slice(0, 10)}</p>
          <p>{entry.data.summary}</p>
          {
            entry.data.coverImage && (
              <Image
                src={entry.data.coverImage}
                alt={entry.data.coverAlt ?? `${entry.data.title} image`}
                widths={[640, 960, 1280]}
                sizes="(max-width: 900px) 92vw, 680px"
                loading="lazy"
              />
            )
          }
          <entry.Content />
        </li>
      ))
    }
  </ul>
</BaseLayout>
