---
import bindRuneLeft from "../../public/image/hero/BindRune_1.jpg";
import bindRuneRight from "../../public/image/hero/BindRune_2.jpg";
import { Image } from "astro:assets";

interface Props {
  title: string;
  tagline: string;
  logoSrc?: string;
  logoAlt?: string;
  bannerText?: string;
  runicName?: string;
  availabilityText?: string;
  bookingEmail?: string;
}

const {
  title,
  tagline,
  logoSrc = "/image/Athas_Logo_transparent.png",
  logoAlt = "Aþas logo",
  bannerText,
  runicName = "ᚪᚦᚪᚴ",
  availabilityText,
  bookingEmail,
} = Astro.props;
---

<header class="hero">
  <div class="hero-art" aria-hidden="true">
    <Image
      src={bindRuneLeft}
      alt=""
      class="hero-bindrune hero-bindrune-left"
      width={1518}
      height={2047}
      loading="eager"
      decoding="async"
      sizes="38vw"
    />
    <Image
      src={bindRuneRight}
      alt=""
      class="hero-bindrune hero-bindrune-right"
      width={1518}
      height={2047}
      loading="eager"
      decoding="async"
      sizes="38vw"
    />
  </div>
  <p class="hero-banner">{bannerText}</p>
  <p class="hero-subline">{tagline}</p>
  <h1>{title}</h1>
  <p class="hero-runes" aria-label="Runic inscription of Aþas">{runicName}</p>
  <p class="hero-availability">{availabilityText}</p>
  <Image
    src={logoSrc}
    alt={logoAlt}
    class="hero-logo"
    width={1941}
    height={2706}
    loading="eager"
    decoding="async"
    sizes="(max-width: 900px) 88vw, 700px"
  />
  {
    bookingEmail && (
      <p class="hero-contact">
        Contact: <a href={`mailto:${bookingEmail}`}>{bookingEmail}</a>
      </p>
    )
  }
</header>
