---
import { getCollection, getEntry, render } from "astro:content";
import AudioPlayer from "../components/AudioPlayer.astro";
import Card from "../components/Card.astro";
import ContactBlock from "../components/ContactBlock.astro";
import Hero from "../components/Hero.astro";
import Panel from "../components/Panel.astro";
import Section from "../components/Section.astro";
import SocialLinks from "../components/SocialLinks.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const home = await getEntry("pages", "home");

if (!home) {
  throw new Error("Homepage content entry is missing.");
}

const { Content } = await render(home);

const releases = await getCollection("releases");
const updates = await getCollection("updates");

const latestUpdate = updates.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];
const latestRelease = releases[0];
---

<BaseLayout title={home.data.seoTitle} description={home.data.seoDescription}>
  <Hero
    title={home.data.title}
    tagline={home.data.tagline}
    logoSrc="/image/Athas_Logo_transparent.png"
    logoAlt="Aþas band logo"
    bannerText={home.data.banner_text}
    availabilityText="Available for booking · Open to label collaborations"
    bookingEmail={home.data.bookingEmail}
  />

  <Section title="Listen" sectionId="listen">
    <Panel variant="feature">
      <p class="listen-hook">A first descent into Athas.</p>
      <p class="listen-meta">Liegetsliht : Excerpt from upcoming release</p>
      <AudioPlayer src="/music/Liegetsliht_demo.mp3" />
      <p class="listen-note">Demo excerpt. Full release forthcoming.</p>
    </Panel>
  </Section>

  <Section title="The Vision" sectionId="vision">
    <Panel>
      <div class="vision"><Content /></div>
    </Panel>
  </Section>

  <Section title="Current Work" sectionId="work">
    <Panel>
      <p class="status">{home.data.status}</p>
      <ul class="current-highlights">
        <li>Debut album <em>Dustsceáwung</em> : instruments and vocals tracked; mixing underway.</li>
        <li>Live lineup rehearsing : preparing for the stage.</li>
        <li>Open to label, promoter, and booking collaborations.</li>
      </ul>
    </Panel>
  </Section>

  <Section title="Updates" sectionId="updates">
    <p class="section-intro">
      News and Instagram posts from Aþas : studio progress, lore, and announcements.
    </p>
    <div class="teaser-grid">
      {
        latestUpdate && (
          <Card
            label="Latest post"
            title={latestUpdate.data.title}
            meta={latestUpdate.data.date.toISOString().slice(0, 10)}
            lines={[latestUpdate.data.summary]}
            href="/updates"
            linkText="View all updates"
          />
        )
      }

      {
        latestRelease && (
          <Card
            label="Current release"
            title={latestRelease.data.title}
            meta={latestRelease.data.format}
            lines={[
              `Status: ${latestRelease.data.status}`,
              `Release: ${latestRelease.data.releaseDate}`,
            ]}
            href="/releases"
            linkText="View releases"
          />
        )
      }
    </div>
  </Section>

  <Section title="Press Kit" sectionId="presskit">
    <Panel>
      <p class="presskit-intro">
        Includes everything needed for booking, coverage, and collaborations.
      </p>
      <ul class="presskit-list">
        <li>Band biography and project concept</li>
        <li>Audio excerpts and release information</li>
        <li>Visual identity assets and key links</li>
      </ul>
      <a class="cta" href="/press-kit">Open full press kit</a>
    </Panel>
  </Section>

  <Section title="Contact" sectionId="contact">
    <p class="contact-intro">
      For bookings, support slots, and collaborations, reach out directly.
    </p>
    <ContactBlock bookingEmail={home.data.bookingEmail} />
    <div class="contact-socials">
      <SocialLinks socials={home.data.socials} />
    </div>
  </Section>
</BaseLayout>

<style>
  .listen-hook {
    margin: 0 0 0.42rem;
    color: #e0cd9e;
    font-size: 0.95rem;
  }

  .listen-meta {
    margin: 0 0 0.55rem;
    font-family: "Ringbearer", "Times New Roman", serif;
    color: #d8c18b;
    letter-spacing: 0.06em;
    font-size: 0.94rem;
  }

  .listen-note {
    margin: 0.55rem 0 0;
    color: #bdb5a2;
    font-size: 0.9rem;
  }

  .vision :global(p) {
    margin: 0 0 0.85rem;
    font-size: clamp(0.8rem, 0.7rem + 0.24vw, 0.94rem);
  }

  .vision :global(p:last-child) {
    margin-bottom: 0;
  }

  .status {
    margin: 0 0 0.75rem;
  }

  .current-highlights {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.4rem;
    color: #cec7b5;
  }

  .teaser-grid {
    display: grid;
    gap: 0.75rem;
  }

  .presskit-intro {
    margin: 0 0 0.5rem;
    color: #dcc794;
    font-family: "Ringbearer", "Times New Roman", serif;
    font-size: 1rem;
  }

  .presskit-list {
    margin: 0 0 0.7rem;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.36rem;
  }

  .cta {
    display: inline-block;
    border: 1px solid rgba(181, 150, 90, 0.35);
    border-radius: 999px;
    padding: 0.2rem 0.62rem;
    font-size: 0.84rem;
    color: #e0cd9e;
  }

  .cta:hover {
    text-decoration: none;
    background: rgba(181, 150, 90, 0.14);
  }

  .contact-intro {
    margin: 0 0 0.8rem;
    color: #c9c2b0;
  }

  .contact-socials {
    display: block;
  }
</style>
