---
import { getCollection, getEntry, render } from "astro:content";
import { Image } from "astro:assets";
import AudioPlayer from "../components/AudioPlayer.astro";
import ContactBlock from "../components/ContactBlock.astro";
import Hero from "../components/Hero.astro";
import Panel from "../components/Panel.astro";
import Section from "../components/Section.astro";
import SocialLinks from "../components/SocialLinks.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import fallbackArtwork from "../assets/brand/Athas_Logo_transparent.png";

const home = await getEntry("pages", "home");

if (!home) {
  throw new Error("Homepage content entry is missing.");
}

const { Content } = await render(home);

const releases = await getCollection("releases");
const updates = await getCollection("updates");

const latestUpdate = updates.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];
const latestRelease = releases[0];
const releaseArt = latestRelease?.data.artworkImage ?? fallbackArtwork;
---

<BaseLayout title={home.data.seoTitle} description={home.data.seoDescription}>
  <Hero
    title={home.data.title}
    tagline={home.data.tagline}
    logoAlt="Aþas band logo"
    bannerText={home.data.banner_text}
    availabilityText="Available for booking · Open to label collaborations"
    bookingEmail={home.data.bookingEmail}
  />

  <Section title="Listen" sectionId="listen">
    <Panel variant="feature">
      <div class="listen-panel">
        <p class="listen-hook">A first descent into Athas.</p>
        <p class="listen-meta">Liegetsliht : Excerpt from upcoming release</p>
        <AudioPlayer src="/music/Liegetsliht_demo.mp3" />
        <p class="listen-note">Demo excerpt. Full release forthcoming.</p>
      </div>
    </Panel>
  </Section>

  {
    latestRelease && (
      <Section title="The Record" sectionId="record">
        <a class="image-teaser" href="/releases">
          <div class="image-teaser-media record-teaser-media">
            <Image
              src={releaseArt}
              alt={
                latestRelease.data.artworkAlt ??
                `${latestRelease.data.title} artwork`
              }
              class="record-teaser-art"
              widths={[320, 480, 640]}
              sizes="(max-width: 900px) 56vw, 220px"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="image-teaser-copy">
            <p class="image-teaser-label">Current release</p>
            <h3>{latestRelease.data.title}</h3>
            <p class="image-teaser-meta">{latestRelease.data.format}</p>
            <p class="image-teaser-body">
              Status: {latestRelease.data.status}
            </p>
            <span class="image-teaser-link">View releases</span>
          </div>
        </a>
      </Section>
    )
  }

  {
    latestUpdate && (
      <Section title="Chronicle" sectionId="chronicle">
        <a class="image-teaser" href="/updates">
          {
            latestUpdate.data.coverImage && (
              <div class="image-teaser-media">
                <Image
                  src={latestUpdate.data.coverImage}
                  alt={
                    latestUpdate.data.coverAlt ?? latestUpdate.data.title
                  }
                  widths={[480, 720, 960]}
                  sizes="(max-width: 900px) 92vw, 420px"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )
          }
          <div class="image-teaser-copy">
            <p class="image-teaser-label">Latest post</p>
            <h3>{latestUpdate.data.title}</h3>
            <p class="image-teaser-meta">
              {latestUpdate.data.date.toISOString().slice(0, 10)}
            </p>
            <p class="image-teaser-body">{latestUpdate.data.summary}</p>
            <span class="image-teaser-link">View all updates</span>
          </div>
        </a>
      </Section>
    )
  }

  <Section title="The Vision" sectionId="vision">
    <Panel>
      <div class="vision"><Content /></div>
      <a class="vision-more" href="/press-kit">Full biography in the press kit</a>
    </Panel>
  </Section>

  <Section title="Contact" sectionId="contact">
    <p class="contact-intro">
      For bookings, support slots, and collaborations, reach out directly.
    </p>
    <ContactBlock bookingEmail={home.data.bookingEmail} />
    <div class="contact-socials">
      <SocialLinks socials={home.data.socials} />
    </div>
  </Section>
</BaseLayout>

<style>
  .listen-panel {
    transition: box-shadow 280ms ease, border-color 280ms ease;
  }

  .listen-hook {
    margin: 0 0 0.42rem;
    color: #e0cd9e;
    font-size: 0.95rem;
  }

  .listen-meta {
    margin: 0 0 0.55rem;
    font-family: "Ringbearer", "Times New Roman", serif;
    color: #d8c18b;
    letter-spacing: 0.06em;
    font-size: 0.94rem;
  }

  .listen-note {
    margin: 0.55rem 0 0;
    color: #bdb5a2;
    font-size: 0.9rem;
  }

  .vision {
    max-height: 12.5rem;
    overflow: hidden;
    mask-image: linear-gradient(180deg, #000 55%, transparent 100%);
    -webkit-mask-image: linear-gradient(180deg, #000 55%, transparent 100%);
  }

  .vision :global(p) {
    margin: 0 0 0.85rem;
    font-size: clamp(0.8rem, 0.7rem + 0.24vw, 0.94rem);
  }

  .vision :global(p:last-child) {
    margin-bottom: 0;
  }

  .vision-more {
    display: inline-block;
    margin-top: 0.75rem;
    border: 1px solid rgba(181, 150, 90, 0.35);
    border-radius: 999px;
    padding: 0.2rem 0.62rem;
    font-size: 0.84rem;
    color: #e0cd9e;
  }

  .vision-more:hover {
    text-decoration: none;
    background: rgba(181, 150, 90, 0.14);
  }

  .image-teaser {
    display: grid;
    gap: 1rem;
    align-items: center;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(181, 150, 90, 0.28);
    border-radius: 6px;
    padding: 0.85rem;
    background: linear-gradient(
      160deg,
      rgba(181, 150, 90, 0.1) 0%,
      rgba(0, 0, 0, 0.25) 55%
    );
    transition:
      border-color 220ms ease,
      background 220ms ease,
      transform 280ms ease;
  }

  .image-teaser:hover {
    text-decoration: none;
    border-color: rgba(220, 196, 123, 0.45);
    background: linear-gradient(
      160deg,
      rgba(181, 150, 90, 0.16) 0%,
      rgba(0, 0, 0, 0.3) 55%
    );
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .image-teaser {
      transition: border-color 220ms ease, background 220ms ease;
    }

    .image-teaser:hover {
      transform: none;
    }
  }

  @media (min-width: 720px) {
    .image-teaser {
      grid-template-columns: minmax(140px, 220px) 1fr;
      gap: 1.25rem;
      padding: 1rem 1.15rem;
    }
  }

  .image-teaser-media {
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(181, 150, 90, 0.22);
    background: rgba(0, 0, 0, 0.4);
  }

  .image-teaser-media :global(img) {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .record-teaser-media {
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    border-radius: 50%;
    clip-path: circle(50% at 50% 50%);
    background:
      radial-gradient(circle at 50% 50%, #1a1a1e 0%, #0e0e10 70%);
  }

  .record-teaser-media :global(img),
  .record-teaser-art {
    width: 72%;
    height: auto;
    aspect-ratio: auto;
    object-fit: contain;
    padding: 0;
  }

  .image-teaser-label {
    margin: 0 0 0.25rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c8b58c;
  }

  .image-teaser-copy h3 {
    margin: 0 0 0.35rem;
    color: #dcc794;
    font-size: 1.14rem;
    font-family: "Ringbearer", "Times New Roman", serif;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .image-teaser-meta {
    margin: 0 0 0.45rem;
    color: #bbaf94;
    font-size: 0.92rem;
  }

  .image-teaser-body {
    margin: 0 0 0.7rem;
    color: #cec7b5;
    font-size: 0.95rem;
  }

  .image-teaser-link {
    display: inline-block;
    border: 1px solid rgba(181, 150, 90, 0.35);
    border-radius: 999px;
    padding: 0.2rem 0.62rem;
    font-size: 0.84rem;
    color: #e0cd9e;
  }

  .image-teaser:hover .image-teaser-link {
    background: rgba(181, 150, 90, 0.14);
  }

  .contact-intro {
    margin: 0 0 0.8rem;
    color: #c9c2b0;
  }

  .contact-socials {
    display: block;
  }
</style>
