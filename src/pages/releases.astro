---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ReleaseArtwork from "../components/ReleaseArtwork.astro";
import fallbackArtwork from "../assets/brand/Athas_Logo_transparent.png";

const releases = await getCollection("releases");
const renderedReleases = await Promise.all(
  releases.map(async (release) => {
    const { Content } = await render(release);

    return {
      ...release,
      Content,
    };
  }),
);
---

<BaseLayout title="Aþas | Releases" description="Aþas releases and status.">
  <h1>Releases</h1>
  <ul class="stack-list">
    {
      renderedReleases.map((release, index) => (
        <li class="stack-item section release-card">
          <p class="release-kicker">{release.data.format}</p>
          <h2>{release.data.title}</h2>
          <ReleaseArtwork
            src={release.data.artworkImage ?? fallbackArtwork}
            alt={release.data.artworkAlt ?? `${release.data.title} artwork preview`}
            title={release.data.title}
            href={release.data.bandcampUrl}
            priority={index === 0}
          />
          <p class="release-meta">Status: {release.data.status}</p>
          <p class="release-meta">Release: {release.data.releaseDate}</p>
          <div class="release-lore">
            <release.Content />
          </div>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .release-kicker {
    margin: 0 0 0.3rem;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #b5965a;
  }

  .release-meta {
    margin: 0.2rem 0;
    color: #bbaf94;
    font-size: 0.92rem;
  }

  .release-lore {
    margin-top: 1rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(181, 150, 90, 0.18);
  }

  .release-lore :global(p) {
    margin: 0 0 0.75rem;
  }
</style>
