---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
  title?: string;
  href?: string;
  priority?: boolean;
}

const { src, alt, title, href, priority = false } = Astro.props;
const hasLink = Boolean(href);
---

<div class="release-artwork">
  {
    hasLink ? (
      <a
        class="release-artwork-link is-clickable"
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Open ${title ?? "this release"} page`}
      >
        <div class="atropos release-artwork-atropos" data-atropos>
          <div class="atropos-scale">
            <div class="atropos-rotate">
              <div class="atropos-inner">
                <div class="release-artwork-mockup">
                  <span class="release-cd-shadow" aria-hidden="true" data-atropos-offset="-8"></span>
                  <div class="release-cd-surface" data-atropos-offset="2">
                    <Image
                      src={src}
                      alt={alt}
                      widths={[420, 640, 960]}
                      sizes="(max-width: 900px) 84vw, 360px"
                      loading={priority ? "eager" : "lazy"}
                      fetchpriority={priority ? "high" : "auto"}
                      decoding="async"
                    />
                    <span class="release-cd-iridescence" aria-hidden="true" data-atropos-offset="6"></span>
                    <span class="release-cd-rings" aria-hidden="true" data-atropos-offset="3"></span>
                    <span class="release-cd-hole" aria-hidden="true" data-atropos-offset="9"></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </a>
    ) : (
      <div class="release-artwork-link">
        <div class="atropos release-artwork-atropos" data-atropos>
          <div class="atropos-scale">
            <div class="atropos-rotate">
              <div class="atropos-inner">
                <div class="release-artwork-mockup">
                  <span class="release-cd-shadow" aria-hidden="true" data-atropos-offset="-8"></span>
                  <div class="release-cd-surface" data-atropos-offset="2">
                    <Image
                      src={src}
                      alt={alt}
                      widths={[420, 640, 960]}
                      sizes="(max-width: 900px) 84vw, 360px"
                      loading={priority ? "eager" : "lazy"}
                      fetchpriority={priority ? "high" : "auto"}
                      decoding="async"
                    />
                    <span class="release-cd-iridescence" aria-hidden="true" data-atropos-offset="6"></span>
                    <span class="release-cd-rings" aria-hidden="true" data-atropos-offset="3"></span>
                    <span class="release-cd-hole" aria-hidden="true" data-atropos-offset="9"></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    )
  }
  <p class="release-artwork-caption">
    {title ? `${title} artwork` : "Release artwork preview"}
    {hasLink && " · Open on Bandcamp"}
  </p>
</div>

<style>
  .release-artwork {
    margin: 0.25rem 0 1rem;
    text-align: center;
  }

  .release-artwork-link {
    display: block;
    width: fit-content;
    margin: 0 auto;
    text-decoration: none;
    color: inherit;
  }

  .release-artwork-atropos {
    width: min(84vw, 360px);
    margin: 0 auto;
  }

  .release-artwork-atropos :global(.atropos-inner) {
    background: transparent;
    overflow: visible;
  }

  .release-artwork-mockup {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    margin: 0 auto;
  }

  .release-cd-shadow {
    position: absolute;
    inset: 10%;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(0, 0, 0, 0.42) 0%,
      rgba(0, 0, 0, 0) 68%
    );
    filter: blur(8px);
  }

  .release-cd-surface {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(198, 195, 181, 0.34);
    box-shadow:
      0 12px 28px rgba(0, 0, 0, 0.42),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .release-cd-surface :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.04) brightness(0.9);
  }

  .release-cd-iridescence {
    position: absolute;
    inset: 0;
    background:
      conic-gradient(from 25deg, rgba(121, 128, 204, 0.26), rgba(153, 218, 231, 0.2), rgba(236, 179, 220, 0.24), rgba(121, 128, 204, 0.26)),
      radial-gradient(circle at 28% 26%, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0) 58%);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .release-cd-rings {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle, rgba(255, 255, 255, 0) 0 13%, rgba(196, 186, 164, 0.85) 13% 16%, rgba(57, 58, 69, 0.76) 16% 18%, rgba(197, 186, 164, 0.44) 18% 25%, rgba(255, 255, 255, 0) 25% 100%),
      repeating-radial-gradient(circle, rgba(255, 255, 255, 0) 0 8.6%, rgba(220, 211, 186, 0.08) 8.6% 9.2%);
    pointer-events: none;
  }

  .release-cd-hole {
    position: absolute;
    inset: 40%;
    border-radius: 50%;
    border: 1px solid rgba(38, 39, 46, 0.5);
    background: rgba(245, 240, 228, 0.82);
    box-shadow: inset 0 0 8px rgba(0, 0, 0, 0.25);
    pointer-events: none;
  }

  .release-artwork-link.is-clickable:focus-visible {
    outline: 1px solid rgba(220, 196, 123, 0.72);
    outline-offset: 3px;
  }

  .release-artwork-caption {
    margin: 0.55rem 0 0;
    font-size: 0.82rem;
    color: #bdae89;
    text-align: center;
    letter-spacing: 0.03em;
  }

  @media (prefers-reduced-motion: reduce) {
    .release-artwork-atropos :global(*) {
      transition: none !important;
    }
  }
</style>
